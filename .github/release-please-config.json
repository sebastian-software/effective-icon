{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "changelog-path": "CHANGELOG.md",
  "packages": {
    ".": {
      "release-type": "node",
      "package-name": "@effective/icon",
      "extra-files": [
        {
          "type": "json",
          "path": "packages/packs/core-line-free/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/packs/core-solid-free/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/packs/core-remix-free/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/packs/core-line-free/manifest.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/packs/core-solid-free/manifest.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/packs/core-remix-free/manifest.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}

{
  "name": "vite-plugin-streamline",
  "version": "0.1.0",
  "description": "Vite plugin for compile-time Streamline icon resolution",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./compile": {
      "import": "./dist/compile.js",
      "types": "./dist/compile.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:demo": "vite build --config demo/vite.config.ts",
    "dev:demo": "vite --config demo/vite.config.ts",
    "download:free": "pnpm --filter @streamline-pkg/streamline-builder download-all",
    "download:set": "pnpm --filter @streamline-pkg/streamline-builder download-set",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:streamline": "tsx scripts/sync-streamline.ts",
    "validate:packs": "pnpm --filter @streamline-pkg/streamline-builder validate-packs"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "streamline",
    "icons",
    "svg"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0-beta.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.0.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.20.6",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}

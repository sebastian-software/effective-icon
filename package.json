{
  "name": "iconkit",
  "version": "0.1.0",
  "description": "Compile-time icon toolkit with framework integrations and package-backed icon resolution",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite-plugin": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    },
    "./compile": {
      "import": "./dist/compile.js",
      "types": "./dist/compile.d.ts"
    },
    "./runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:demo": "node --import tsx scripts/build-demo.ts",
    "dev:demo": "node --import tsx scripts/dev-demo.ts",
    "dev:demo:image": "pnpm --filter @streamline-demo/image dev",
    "dev:demo:mask": "pnpm --filter @streamline-demo/mask dev",
    "dev:demo:inline-svg": "pnpm --filter @streamline-demo/inline-svg dev",
    "dev:demo:web-component": "pnpm --filter @streamline-demo/web-component dev",
    "download:free": "pnpm --filter @icon-pkg/streamline-builder download-all",
    "download:set": "pnpm --filter @icon-pkg/streamline-builder download-set",
    "release:packs:check": "pnpm --filter @icon-pkg/streamline-builder release-check",
    "release:packs:publish": "pnpm --filter @icon-pkg/streamline-builder publish-release",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "sync:streamline": "tsx scripts/sync-streamline.ts",
    "validate:packs": "pnpm --filter @icon-pkg/streamline-builder validate-packs"
  },
  "keywords": [
    "iconkit",
    "icons",
    "svg",
    "vite",
    "vite-plugin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/iconkit.git"
  },
  "homepage": "https://github.com/sebastian-software/iconkit#readme",
  "bugs": {
    "url": "https://github.com/sebastian-software/iconkit/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0-beta.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.0.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.20.6",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}

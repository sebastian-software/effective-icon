{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@streamline-demo/shared": ["./packages/demo-shared/src/index.ts"],
      "@streamline-demo/shared/styles.css": ["./packages/demo-shared/src/styles.css"],
      "vite-plugin-streamline": ["./src/index.ts"],
      "vite-plugin-streamline/compile": ["./src/compile.ts"],
      "vite-plugin-streamline/runtime": ["./src/runtime.ts"]
    },
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "types": ["node", "vitest/globals", "vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "test/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "demo/**/*.ts",
    "demo/**/*.tsx",
    "demo.d.ts",
    "fixtures/**/*.ts",
    "fixtures/**/*.tsx"
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@streamline-demo/shared": ["./packages/demo-shared/src/index.ts"],
      "@streamline-demo/shared/react-app": ["./packages/demo-shared/src/react-app.tsx"],
      "@streamline-demo/shared/solid-app": ["./packages/demo-shared/src/solid-app.tsx"],
      "@streamline-demo/shared/styles.css": ["./packages/demo-shared/src/styles.css"],
      "@fixture/app": ["./fixtures/vite-app/main-jsx.tsx"],
      "@effective/icon": ["./src/index.ts"],
      "@effective/icon/vite-plugin": ["./src/plugin.ts"],
      "@effective/icon/compile": ["./src/compile.ts"],
      "@effective/icon/runtime": ["./src/runtime.ts"]
    },
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "types": ["node", "vitest/globals", "vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "test/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "demo/**/*.ts",
    "demo/**/*.tsx",
    "demo.d.ts",
    "fixtures/**/*.ts",
    "fixtures/**/*.tsx"
  ]
}
